{
  "name": "template",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 5377",
    "build": "next build --webpack",
    "lint": "eslint .",
    "start": "next start -p 5377",
    "import:supabase": "node ./scripts/import-supabase.mjs",
    "electron:dev": "concurrently \"next dev --webpack -p 5377\" \"wait-on http://localhost:5377 && cross-env ELECTRON_START_URL=http://localhost:5377 electron .\"",
    "electron:build": "next build --webpack && electron-builder",
    "electron:preview": "concurrently \"next start -p 5377\" \"wait-on http://localhost:5377 && cross-env ELECTRON_START_URL=http://localhost:5377 electron .\""
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "better-sqlite3": "^12.6.2",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.34.0",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.veles.app",
    "productName": "Veles",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon-256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
